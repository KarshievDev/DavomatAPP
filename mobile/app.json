{
  "expo": {
    "name": "DavomatAppNew",
    "slug": "davomatapp-new",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/davomat_logo.png",
    "newArchEnabled": true,
    "scheme": "davomatapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.karshiev.davomatappnew",
      "buildNumber": "2",
      "newArchEnabled": true,
      "supportsTablet": true,
      "entitlements": {
        "aps-environment": "production"
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Ishga kelish va ketish vaqtini qayd etish uchun joylashuvingizni aniqlashimiz kerak.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Ish joyida ekanligingizni tekshirish uchun joylashuv xizmati kerak.",
        "NSLocationAlwaysUsageDescription": "Ilova fonda bo'lganda ham ish joyini tekshirish uchun ruxsat kerak.",
        "NSCameraUsageDescription": "Ishga kelgan vaqtda yuzingizni suratga olish uchun kameradan foydalanamiz.",
        "NSPhotoLibraryUsageDescription": "Suratni saqlash yoki profil rasmini yangilash uchun galereyadan foydalanamiz.",
        "CFBundleDisplayName": "DavomatAppNew"
      }
    },
    "android": {
      "package": "com.karshiev.davomatappnew",
      "versionCode": 2,
      "newArchEnabled": true,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.CAMERA",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/davomat_logo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Ish joyida ekanligingizni fonda ham tekshirish uchun ruxsat kerak.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/davomat_logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-camera",
      "expo-image-picker",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0",
            "kotlinVersion": "2.1.0"
          }
        }
      ],
      "expo-image",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e0fc4927-e68a-4ef6-b62d-1ca146460dd8"
      }
    },
    "owner": "abdumalikdev"
  }
}
